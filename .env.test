HEADLESS=true
VOLUNTEER_SLOT_CALENDAR_ID=volcalid
APPOINTMENT_SLOT_CALENDAR_ID=appcalid

# Stripe placeholders for VCR-backed tests
STRIPE_API_KEY=STRIPEAPIKEY1234
STRIPE_PUBLISHABLE_KEY=STRIPEPUBLISHABLEKEY1234

# Square placeholders for tests that build SquareCheckout directly
SQUARE_ACCESS_TOKEN=SQACCESSTOKEN1234
SQUARE_LOCATION_ID=SQLOCID1234
SQUARE_ENVIRONMENT=sandbox

# Feature flags exercised by the test suite
FEATURE_MAINTENANCE_WORKFLOW=on
FEATURE_RESERVABLE_ITEMS=on
FEATURE_SMS_REMINDERS=on
FEATURE_STRIPE_PAYMENTS=on
FEATURE_NEW_APPOINTMENTS_PAGE=false
