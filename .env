# This file lists the environment variables the application uses.
#
# !!! HEADS UP !!!
# This file is committed AND loaded by dotenv on every Heroku dyno at
# boot. Anything you set here becomes a production default unless
# Heroku config explicitly overrides it. DO NOT SET VALUES HERE.
#
# Dev defaults live in .env.development (loaded automatically in dev).
# Test defaults live in .env.test.
# Personal overrides go in .env.local.
# Production values live in Heroku config.

# Database credentials
# PGUSER=
# PGPASSWORD=
# PGHOST=

# Square API is uses to process online payments
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=
# SQUARE_ENVIRONMENT=

# Stripe API key
# STRIPE_API_KEY=
# STRIPE_PUBLISHABLE_KEY=
# Secret value used to sign webhook payloads
# STRIPE_WEBHOOK_SIGNING_SECRET=

## Google Calendar (see README for details)
#
# Path to Google service account credentials (used in prod)
# GOOGLE_APPLICATION_CREDENTIALS=
#
# Use these values for local development
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# Calendar to use for volunteer slots
# VOLUNTEER_SLOT_CALENDAR_ID=

# Calendar to use for hold slots
# APPOINTMENT_SLOT_CALENDAR_ID=

# Bucketeer provides AWS credentials without needing an Amazon account. Used to store image and file uploads.
# BUCKETEER_AWS_ACCESS_KEY_ID=
# BUCKETEER_AWS_SECRET_ACCESS_KEY=
# BUCKETEER_AWS_REGION=
# BUCKETEER_BUCKET_NAME=

# Require basic authentication (useful for staging sites)
# HTTP_BASIC_USERS=

# Sendgrid is used to send email
# SENDGRID_USERNAME=
# SENDGRID_PASSWORD=

# Features that can be toggled
# FEATURE_MAINTENANCE_WORKFLOW=
# FEATURE_RESERVABLE_ITEMS=
# FEATURE_SMS_REMINDERS=
# FEATURE_NEW_APPOINTMENTS_PAGE=
# FEATURE_STRIPE_PAYMENTS=

# Twilio is used for SMS notifications
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# The Twilio integration requires either a from phone number or a messaging
# service be specified.
# TWILIO_PHONE_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID=

CAMPING_HOMEPAGE_URL=https://www.chicagotoollibrary.org/camping